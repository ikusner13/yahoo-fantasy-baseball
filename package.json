{
  "name": "fantasy-baseball",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered Yahoo fantasy baseball GM",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "scripts": {
    "dev": "alchemy dev --stage dev --env-file .env.local",
    "deploy:dev": "alchemy deploy --stage dev --env-file .env.local",
    "deploy:prod": "alchemy deploy --stage prod --env-file .env.local",
    "check": "vp check && vpr effect:check",
    "typecheck": "vp check",
    "effect:check": "tsgo -p tsconfig.json --noEmit",
    "effect:patch": "effect-tsgo patch",
    "test": "vp test run",
    "test:watch": "vp test",
    "eval": "evalite",
    "eval:watch": "evalite watch",
    "eval:waiver": "evalite legacy/tests/evals/waiver-wire.eval.ts",
    "eval:lineup": "evalite legacy/tests/evals/lineup-summary.eval.ts",
    "eval:matchup": "evalite legacy/tests/evals/matchup-strategy.eval.ts",
    "eval:trade": "evalite legacy/tests/evals/trade-proposal.eval.ts",
    "eval:injury": "evalite legacy/tests/evals/injury-assessment.eval.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "prepare": "vp config && vpr effect:patch"
  },
  "dependencies": {
    "alchemy": "2.0.0-beta.52",
    "drizzle-orm": "1.0.0-rc.3",
    "effect": "4.0.0-beta.78",
    "hono": "^4.12.10",
    "workers-tagged-logger": "^1.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@effect/platform-node": "4.0.0-beta.78",
    "@effect/tsgo": "^0.14.0",
    "@effect/vitest": "4.0.0-beta.78",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260606.1",
    "dotenv": "^17.4.0",
    "drizzle-kit": "1.0.0-rc.3",
    "evalite": "^0.19.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.22.0"
  },
  "packageManager": "pnpm@10.33.0"
}
